{
  "name": "ct-segmentation-viewer-app",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "electron": "electron .",
    "electron:dev": "electron .",
    "build:frontend": "NEXT_PUBLIC_API_URL=http://127.0.0.1:8000 npm --prefix frontend run build",
    "build:backend": "backend/.venv-packaging/bin/python -m PyInstaller backend/ct_viewer_backend.spec --distpath backend/dist --workpath backend/build",
    "build:app": "electron-builder --mac",
    "dist": "npm run build:frontend && npm run build:backend && npm run build:app"
  },
  "build": {
    "appId": "com.ctviewer.app",
    "productName": "CT Segmentation Viewer",
    "mac": {
      "category": "public.app-category.medical",
      "icon": "firefly-ct.ico",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "electron/**",
      "frontend/out/**"
    ],
    "extraResources": [
      {
        "from": "backend/dist/ct-viewer-backend",
        "to": "ct-viewer-backend"
      }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
